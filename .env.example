# Local environment variables for LIZI
# Copy this file to .env.local or .env and update values as needed.

# Optional backend auth API base URL
VITE_AUTH_API_URL=http://localhost:4000

# Optional Supabase-like config if you want to replace mock auth
VITE_SUPABASE_URL=https://your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
